rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isActiveStaff() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/staff_allowlist/$(request.auth.uid))
        && get(/databases/$(database)/documents/staff_allowlist/$(request.auth.uid)).data.active == true;
    }

    function isValidDateString(value) {
      return value is string && value.matches('^\\d{4}-\\d{2}-\\d{2}$');
    }

    function isValidServiceType(value) {
      return value == 'pickup' || value == 'return';
    }

    function isValidTimeHHmm(value) {
      return value is string && value.matches('^([01]\\d|2[0-3]):([0-5]\\d)$');
    }

    function dateStringToTimestamp(value) {
      return timestamp.date(
        int(value[0:4]),
        int(value[5:7]),
        int(value[8:10])
      );
    }

    function lastSundayOfMonth(year, month, lastDay) {
      let lastDate = timestamp.date(year, month, lastDay);
      return lastDay - (lastDate.dayOfWeek() % 7);
    }

    function madeiraisDst(value) {
      let year = value.year();
      let dstStart = timestamp.date(year, 3, lastSundayOfMonth(year, 3, 31)) + duration.value(1, 'h');
      let dstEnd = timestamp.date(year, 10, lastSundayOfMonth(year, 10, 31)) + duration.value(1, 'h');
      return value >= dstStart && value < dstEnd;
    }

    function currentMadeiraServiceDate() {
      return (request.time + (madeiraisDst(request.time) ? duration.value(1, 'h') : duration.value(0, 'h'))).date();
    }

    function isCurrentServiceDate(value) {
      return isValidDateString(value)
        && dateStringToTimestamp(value) == currentMadeiraServiceDate();
    }

    function isValidStatusPayload() {
      return request.resource.data.keys().hasOnly([
          'date',
          'itemId',
          'serviceType',
          'done',
          'updatedAt',
          'updatedByUid',
          'updatedByName',
          'updatedByEmail'
        ])
        && isValidDateString(request.resource.data.date)
        && isCurrentServiceDate(request.resource.data.date)
        && request.resource.data.itemId is string
        && request.resource.data.itemId.size() > 0
        && isValidServiceType(request.resource.data.serviceType)
        && request.resource.data.done is bool
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.updatedByUid == request.auth.uid
        && request.resource.data.updatedByName is string
        && request.resource.data.updatedByEmail is string;
    }

    function isValidTimeOverridePayload() {
      return request.resource.data.keys().hasOnly([
          'date',
          'itemId',
          'serviceType',
          'originalTime',
          'overrideTime',
          'updatedAt',
          'updatedByUid',
          'updatedByName',
          'updatedByEmail'
        ])
        && isValidDateString(request.resource.data.date)
        && isCurrentServiceDate(request.resource.data.date)
        && request.resource.data.itemId is string
        && request.resource.data.itemId.size() > 0
        && isValidServiceType(request.resource.data.serviceType)
        && request.resource.data.originalTime is string
        && isValidTimeHHmm(request.resource.data.overrideTime)
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.updatedByUid == request.auth.uid
        && request.resource.data.updatedByName is string
        && request.resource.data.updatedByEmail is string;
    }

    function isValidReadyPayload() {
      return request.resource.data.keys().hasOnly([
          'date',
          'itemId',
          'serviceType',
          'plate',
          'ready',
          'updatedAt',
          'updatedByUid',
          'updatedByName',
          'updatedByEmail'
        ])
        && isValidDateString(request.resource.data.date)
        && isCurrentServiceDate(request.resource.data.date)
        && request.resource.data.itemId is string
        && request.resource.data.itemId.size() > 0
        && request.resource.data.serviceType == 'pickup'
        && request.resource.data.plate is string
        && request.resource.data.plate.size() > 0
        && request.resource.data.ready is bool
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.updatedByUid == request.auth.uid
        && request.resource.data.updatedByName is string
        && request.resource.data.updatedByEmail is string;
    }

    function isValidStaffProfilePayload(uid) {
      return request.resource.data.keys().hasOnly([
          'uid',
          'displayName',
          'firstName',
          'email',
          'photoURL',
          'updatedAt'
        ])
        && request.resource.data.uid == uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.displayName is string
        && request.resource.data.firstName is string
        && request.resource.data.email is string
        && request.resource.data.photoURL is string
        && request.resource.data.updatedAt is timestamp;
    }

    function hasValidOptionalTimeFields() {
      return (!request.resource.data.keys().hasAny(['oldTime']) || request.resource.data.oldTime is string)
        && (!request.resource.data.keys().hasAny(['newTime']) || request.resource.data.newTime is string);
    }

    function hasValidOptionalReadyFields() {
      return (!request.resource.data.keys().hasAny(['ready']) || request.resource.data.ready is bool)
        && (!request.resource.data.keys().hasAny(['plate']) || request.resource.data.plate is string);
    }

    function isValidActivityPayload(date) {
      return request.resource.data.keys().hasOnly([
          'actionType',
          'date',
          'itemId',
          'serviceType',
          'done',
          'createdAt',
          'updatedByUid',
          'updatedByName',
          'updatedByEmail',
          'itemName',
          'itemTime',
          'reservationId',
          'oldTime',
          'newTime',
          'ready',
          'plate'
        ])
        && (request.resource.data.actionType == 'status_toggle' || request.resource.data.actionType == 'time_change' || request.resource.data.actionType == 'ready_toggle')
        && request.resource.data.date == date
        && isValidDateString(request.resource.data.date)
        && isCurrentServiceDate(request.resource.data.date)
        && request.resource.data.itemId is string
        && request.resource.data.itemId.size() > 0
        && isValidServiceType(request.resource.data.serviceType)
        && request.resource.data.done is bool
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedByUid == request.auth.uid
        && request.resource.data.updatedByName is string
        && request.resource.data.updatedByEmail is string
        && request.resource.data.itemName is string
        && request.resource.data.itemTime is string
        && request.resource.data.reservationId is string
        && hasValidOptionalTimeFields()
        && hasValidOptionalReadyFields()
        && (
          request.resource.data.actionType != 'time_change'
          || (
            request.resource.data.keys().hasAll(['oldTime', 'newTime'])
            && request.resource.data.oldTime is string
            && isValidTimeHHmm(request.resource.data.newTime)
            && request.resource.data.done == false
          )
        )
        && (
          request.resource.data.actionType != 'ready_toggle'
          || (
            request.resource.data.keys().hasAll(['ready', 'plate'])
            && request.resource.data.serviceType == 'pickup'
            && request.resource.data.plate is string
            && request.resource.data.plate.size() > 0
          )
        );
    }

    function isValidRefreshLockPayload(date) {
      return request.resource.data.keys().hasOnly([
          'date',
          'ownerUid',
          'cacheVersion',
          'leaseUntil',
          'updatedAt'
        ])
        && request.resource.data.date == date
        && isValidDateString(request.resource.data.date)
        && request.resource.data.ownerUid is string
        && request.resource.data.ownerUid.size() > 0
        && request.resource.data.cacheVersion is string
        && request.resource.data.cacheVersion.size() > 0
        && request.resource.data.leaseUntil is timestamp
        && request.resource.data.updatedAt is timestamp;
    }

    match /staff_allowlist/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    match /staff_profiles/{uid} {
      allow read: if isActiveStaff();
      allow create, update: if isSignedIn() && request.auth.uid == uid && isValidStaffProfilePayload(uid);
      allow delete: if false;
    }

    match /service_status/{docId} {
      allow read: if isActiveStaff();

      allow create: if isActiveStaff()
        && isValidStatusPayload()
        && docId == request.resource.data.date + "_" + request.resource.data.itemId;

      allow update: if isActiveStaff()
        && isValidStatusPayload()
        && request.resource.data.itemId == resource.data.itemId
        && request.resource.data.date == resource.data.date
        && request.resource.data.serviceType == resource.data.serviceType
        && docId == resource.data.date + "_" + resource.data.itemId;

      allow delete: if false;
    }

    match /service_time_overrides/{docId} {
      allow read: if isActiveStaff();

      allow create: if isActiveStaff()
        && isValidTimeOverridePayload()
        && docId == request.resource.data.date + "_" + request.resource.data.itemId;

      allow update: if isActiveStaff()
        && isValidTimeOverridePayload()
        && docId == resource.data.date + "_" + resource.data.itemId
        && request.resource.data.date == resource.data.date
        && request.resource.data.itemId == resource.data.itemId
        && request.resource.data.serviceType == resource.data.serviceType;

      allow delete: if false;
    }

    match /service_ready/{docId} {
      allow read: if isActiveStaff();

      allow create: if isActiveStaff()
        && isValidReadyPayload()
        && docId == request.resource.data.date + "_" + request.resource.data.itemId;

      allow update: if isActiveStaff()
        && isValidReadyPayload()
        && docId == resource.data.date + "_" + resource.data.itemId
        && request.resource.data.date == resource.data.date
        && request.resource.data.itemId == resource.data.itemId
        && request.resource.data.serviceType == resource.data.serviceType;

      allow delete: if false;
    }

    match /user_settings/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    match /scraped-data/{date} {
      allow read: if isActiveStaff();
      allow write: if false;
    }

    match /service_refresh_locks/{date} {
      allow read: if isActiveStaff();
      allow create, update: if isActiveStaff() && isValidRefreshLockPayload(date);
      allow delete: if false;
    }

    match /service_activity/{date}/entries/{entryId} {
      allow read: if isActiveStaff();
      allow create: if isActiveStaff() && isValidActivityPayload(date);
      allow update, delete: if false;
    }

    // Required for collectionGroup('entries') leaderboard queries.
    match /{path=**}/entries/{entryId} {
      allow read: if isActiveStaff();
      allow write: if false;
    }

    match /access_requests/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    match /access_blocks_uid/{uid} {
      allow read, write: if false;
    }

    match /access_blocks_email/{emailNormalized} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
