rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isActiveStaff() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/staff_allowlist/$(request.auth.uid))
        && get(/databases/$(database)/documents/staff_allowlist/$(request.auth.uid)).data.active == true;
    }

    function isAdminStaff() {
      return isActiveStaff()
        && get(/databases/$(database)/documents/staff_allowlist/$(request.auth.uid)).data.role == 'admin';
    }

    function isValidDateString(value) {
      return value is string && value.matches('^\\d{4}-\\d{2}-\\d{2}$');
    }

    function isValidServiceType(value) {
      return value == 'pickup' || value == 'return';
    }

    function isValidTimeHHmm(value) {
      return value is string && value.matches('^([01]\\d|2[0-3]):([0-5]\\d)$');
    }

    function dateStringToTimestamp(value) {
      return timestamp.date(
        int(value[0:4]),
        int(value[5:7]),
        int(value[8:10])
      );
    }

    function lastSundayOfMonth(year, month, lastDay) {
      let lastDate = timestamp.date(year, month, lastDay);
      return lastDay - (lastDate.dayOfWeek() % 7);
    }

    function madeiraisDst(value) {
      let year = value.year();
      let dstStart = timestamp.date(year, 3, lastSundayOfMonth(year, 3, 31)) + duration.value(1, 'h');
      let dstEnd = timestamp.date(year, 10, lastSundayOfMonth(year, 10, 31)) + duration.value(1, 'h');
      return value >= dstStart && value < dstEnd;
    }

    function currentMadeiraServiceDate() {
      return (request.time + (madeiraisDst(request.time) ? duration.value(1, 'h') : duration.value(0, 'h'))).date();
    }

    function isCurrentServiceDate(value) {
      return isValidDateString(value)
        && dateStringToTimestamp(value) == currentMadeiraServiceDate();
    }

    function isValidStatusPayload() {
      return request.resource.data.keys().hasOnly([
          'date',
          'itemId',
          'serviceType',
          'done',
          'updatedAt',
          'updatedByUid',
          'updatedByName',
          'updatedByEmail'
        ])
        && isValidDateString(request.resource.data.date)
        && isCurrentServiceDate(request.resource.data.date)
        && request.resource.data.itemId is string
        && request.resource.data.itemId.size() > 0
        && isValidServiceType(request.resource.data.serviceType)
        && request.resource.data.done is bool
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.updatedByUid == request.auth.uid
        && request.resource.data.updatedByName is string
        && request.resource.data.updatedByEmail is string;
    }

    function isValidTimeOverridePayload() {
      return request.resource.data.keys().hasOnly([
          'date',
          'itemId',
          'serviceType',
          'originalTime',
          'overrideTime',
          'updatedAt',
          'updatedByUid',
          'updatedByName',
          'updatedByEmail'
        ])
        && isValidDateString(request.resource.data.date)
        && isCurrentServiceDate(request.resource.data.date)
        && request.resource.data.itemId is string
        && request.resource.data.itemId.size() > 0
        && isValidServiceType(request.resource.data.serviceType)
        && request.resource.data.originalTime is string
        && isValidTimeHHmm(request.resource.data.overrideTime)
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.updatedByUid == request.auth.uid
        && request.resource.data.updatedByName is string
        && request.resource.data.updatedByEmail is string;
    }

    function isValidReadyPayload() {
      return request.resource.data.keys().hasOnly([
          'date',
          'itemId',
          'serviceType',
          'plate',
          'ready',
          'updatedAt',
          'updatedByUid',
          'updatedByName',
          'updatedByEmail'
        ])
        && isValidDateString(request.resource.data.date)
        && isCurrentServiceDate(request.resource.data.date)
        && request.resource.data.itemId is string
        && request.resource.data.itemId.size() > 0
        && request.resource.data.serviceType == 'pickup'
        && request.resource.data.plate is string
        && request.resource.data.plate.size() > 0
        && request.resource.data.ready is bool
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.updatedByUid == request.auth.uid
        && request.resource.data.updatedByName is string
        && request.resource.data.updatedByEmail is string;
    }

    function isValidStaffProfilePayload(uid) {
      return request.resource.data.keys().hasOnly([
          'uid',
          'displayName',
          'firstName',
          'email',
          'photoURL',
          'updatedAt'
        ])
        && request.resource.data.uid == uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.displayName is string
        && request.resource.data.firstName is string
        && request.resource.data.email is string
        && request.resource.data.photoURL is string
        && request.resource.data.updatedAt is timestamp;
    }

    function hasValidOptionalTimeFields() {
      return (!request.resource.data.keys().hasAny(['oldTime']) || request.resource.data.oldTime is string)
        && (!request.resource.data.keys().hasAny(['newTime']) || request.resource.data.newTime is string);
    }

    function hasValidOptionalReadyFields() {
      return (!request.resource.data.keys().hasAny(['ready']) || request.resource.data.ready is bool)
        && (!request.resource.data.keys().hasAny(['plate']) || request.resource.data.plate is string);
    }

    function isValidActivityPayload(date) {
      return request.resource.data.keys().hasOnly([
          'actionType',
          'date',
          'itemId',
          'serviceType',
          'done',
          'createdAt',
          'updatedByUid',
          'updatedByName',
          'updatedByEmail',
          'itemName',
          'itemTime',
          'reservationId',
          'oldTime',
          'newTime',
          'ready',
          'plate'
        ])
        && (request.resource.data.actionType == 'status_toggle' || request.resource.data.actionType == 'time_change' || request.resource.data.actionType == 'ready_toggle')
        && request.resource.data.date == date
        && isValidDateString(request.resource.data.date)
        && isCurrentServiceDate(request.resource.data.date)
        && request.resource.data.itemId is string
        && request.resource.data.itemId.size() > 0
        && isValidServiceType(request.resource.data.serviceType)
        && request.resource.data.done is bool
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedByUid == request.auth.uid
        && request.resource.data.updatedByName is string
        && request.resource.data.updatedByEmail is string
        && request.resource.data.itemName is string
        && request.resource.data.itemTime is string
        && request.resource.data.reservationId is string
        && hasValidOptionalTimeFields()
        && hasValidOptionalReadyFields()
        && (
          request.resource.data.actionType != 'time_change'
          || (
            request.resource.data.keys().hasAll(['oldTime', 'newTime'])
            && request.resource.data.oldTime is string
            && isValidTimeHHmm(request.resource.data.newTime)
            && request.resource.data.done == false
          )
        )
        && (
          request.resource.data.actionType != 'ready_toggle'
          || (
            request.resource.data.keys().hasAll(['ready', 'plate'])
            && request.resource.data.serviceType == 'pickup'
            && request.resource.data.plate is string
            && request.resource.data.plate.size() > 0
          )
        );
    }

    function isValidRefreshLockPayload(date) {
      return request.resource.data.keys().hasOnly([
          'date',
          'ownerUid',
          'cacheVersion',
          'leaseUntil',
          'updatedAt'
        ])
        && request.resource.data.date == date
        && isValidDateString(request.resource.data.date)
        && request.resource.data.ownerUid is string
        && request.resource.data.ownerUid.size() > 0
        && request.resource.data.cacheVersion is string
        && request.resource.data.cacheVersion.size() > 0
        && request.resource.data.leaseUntil is timestamp
        && request.resource.data.updatedAt is timestamp;
    }

    function isValidFlightStatusCachePayload(date) {
      return request.resource.data.keys().hasOnly([
          'date',
          'flightNumbers',
          'results',
          'source',
          'cachedAt',
          'updatedByUid'
        ])
        && request.resource.data.date == date
        && isCurrentServiceDate(request.resource.data.date)
        && request.resource.data.flightNumbers is list
        && request.resource.data.flightNumbers.size() > 0
        && request.resource.data.flightNumbers.size() <= 100
        && request.resource.data.results is list
        && request.resource.data.results.size() <= 100
        && request.resource.data.source == 'fr24-unofficial'
        && request.resource.data.cachedAt is timestamp
        && request.resource.data.updatedByUid == request.auth.uid;
    }

    function isValidNullableTimestamp(value) {
      return value == null || value is timestamp;
    }

    function isValidAccessRequestBase(uid) {
      return request.resource.data.keys().hasOnly([
          'uid',
          'email',
          'emailNormalized',
          'displayName',
          'photoURL',
          'status',
          'requestCount',
          'createdAt',
          'updatedAt',
          'lastRequestedAt',
          'decisionType',
          'decisionAt',
          'decisionByUid',
          'decisionByName',
          'decisionByEmail'
        ])
        && request.resource.data.uid == uid
        && request.resource.data.email is string
        && request.resource.data.emailNormalized is string
        && request.resource.data.displayName is string
        && request.resource.data.photoURL is string
        && request.resource.data.requestCount is number
        && request.resource.data.requestCount >= 1
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && isValidNullableTimestamp(request.resource.data.lastRequestedAt)
        && isValidNullableTimestamp(request.resource.data.decisionAt)
        && request.resource.data.decisionType is string
        && request.resource.data.decisionByUid is string
        && request.resource.data.decisionByName is string
        && request.resource.data.decisionByEmail is string;
    }

    function isValidOwnPendingAccessRequest(uid) {
      return isSignedIn()
        && request.auth.uid == uid
        && isValidAccessRequestBase(uid)
        && request.resource.data.status == 'pending'
        && request.resource.data.lastRequestedAt is timestamp
        && request.resource.data.decisionType == ''
        && request.resource.data.decisionAt == null
        && request.resource.data.decisionByUid == ''
        && request.resource.data.decisionByName == ''
        && request.resource.data.decisionByEmail == '';
    }

    function isValidOwnAccessRequestCreate(uid) {
      return isValidOwnPendingAccessRequest(uid)
        && request.resource.data.requestCount == 1;
    }

    function isValidOwnAccessRequestUpdate(uid) {
      return isValidOwnPendingAccessRequest(uid)
        && resource.data.status == 'pending';
    }

    function isValidStaffAccessDecision(uid) {
      return isAdminStaff()
        && resource.data.status == 'pending'
        && isValidAccessRequestBase(uid)
        && (
          (request.resource.data.status == 'approved' && request.resource.data.decisionType == 'approve')
          || (request.resource.data.status == 'denied' && request.resource.data.decisionType == 'deny')
        )
        && request.resource.data.decisionAt is timestamp
        && request.resource.data.decisionByUid == request.auth.uid
        && request.resource.data.decisionByName is string
        && request.resource.data.decisionByEmail is string;
    }

    function isValidAdminBlockedAccessDecision(uid) {
      return isAdminStaff()
        && uid != request.auth.uid
        && isValidAccessRequestBase(uid)
        && request.resource.data.status == 'blocked'
        && request.resource.data.decisionType == 'revoke'
        && request.resource.data.decisionAt is timestamp
        && request.resource.data.decisionByUid == request.auth.uid
        && request.resource.data.decisionByName is string
        && request.resource.data.decisionByEmail is string;
    }

    function isValidStaffRole(value) {
      return value == 'staff' || value == 'admin';
    }

    function isValidStaffAllowlistApproval(uid) {
      return isAdminStaff()
        && request.resource.data.keys().hasOnly([
          'active',
          'role',
          'uid',
          'email',
          'displayName',
          'approvedAt',
          'approvedByUid',
          'approvedByName',
          'approvedByEmail'
        ])
        && request.resource.data.active == true
        && request.resource.data.role == 'staff'
        && request.resource.data.uid == uid
        && request.resource.data.email is string
        && request.resource.data.displayName is string
        && request.resource.data.approvedAt is timestamp
        && request.resource.data.approvedByUid == request.auth.uid
        && request.resource.data.approvedByName is string
        && request.resource.data.approvedByEmail is string;
    }

    function isValidStaffAllowlistRevocation(uid) {
      return isAdminStaff()
        && uid != request.auth.uid
        && resource.data.active == true
        && request.resource.data.keys().hasOnly([
          'active',
          'role',
          'uid',
          'email',
          'displayName',
          'approvedAt',
          'approvedByUid',
          'approvedByName',
          'approvedByEmail',
          'revokedAt',
          'revokedByUid',
          'revokedByName',
          'revokedByEmail'
        ])
        && request.resource.data.active == false
        && isValidStaffRole(request.resource.data.role)
        && request.resource.data.uid == uid
        && request.resource.data.email is string
        && request.resource.data.displayName is string
        && isValidNullableTimestamp(request.resource.data.approvedAt)
        && request.resource.data.approvedByUid is string
        && request.resource.data.approvedByName is string
        && request.resource.data.approvedByEmail is string
        && request.resource.data.revokedAt is timestamp
        && request.resource.data.revokedByUid == request.auth.uid
        && request.resource.data.revokedByName is string
        && request.resource.data.revokedByEmail is string;
    }

    match /staff_allowlist/{uid} {
      allow get: if (isSignedIn() && request.auth.uid == uid) || isAdminStaff();
      allow list: if isAdminStaff();
      allow create: if isValidStaffAllowlistApproval(uid);
      allow update: if isValidStaffAllowlistApproval(uid) || isValidStaffAllowlistRevocation(uid);
      allow delete: if false;
    }

    match /staff_profiles/{uid} {
      allow read: if isActiveStaff();
      allow create, update: if isSignedIn() && request.auth.uid == uid && isValidStaffProfilePayload(uid);
      allow delete: if false;
    }

    match /service_status/{docId} {
      allow read: if isActiveStaff();

      allow create: if isActiveStaff()
        && isValidStatusPayload()
        && docId == request.resource.data.date + "_" + request.resource.data.itemId;

      allow update: if isActiveStaff()
        && isValidStatusPayload()
        && request.resource.data.itemId == resource.data.itemId
        && request.resource.data.date == resource.data.date
        && request.resource.data.serviceType == resource.data.serviceType
        && docId == resource.data.date + "_" + resource.data.itemId;

      allow delete: if false;
    }

    match /service_time_overrides/{docId} {
      allow read: if isActiveStaff();

      allow create: if isActiveStaff()
        && isValidTimeOverridePayload()
        && docId == request.resource.data.date + "_" + request.resource.data.itemId;

      allow update: if isActiveStaff()
        && isValidTimeOverridePayload()
        && docId == resource.data.date + "_" + resource.data.itemId
        && request.resource.data.date == resource.data.date
        && request.resource.data.itemId == resource.data.itemId
        && request.resource.data.serviceType == resource.data.serviceType;

      allow delete: if false;
    }

    match /service_ready/{docId} {
      allow read: if isActiveStaff();

      allow create: if isActiveStaff()
        && isValidReadyPayload()
        && docId == request.resource.data.date + "_" + request.resource.data.itemId;

      allow update: if isActiveStaff()
        && isValidReadyPayload()
        && docId == resource.data.date + "_" + resource.data.itemId
        && request.resource.data.date == resource.data.date
        && request.resource.data.itemId == resource.data.itemId
        && request.resource.data.serviceType == resource.data.serviceType;

      allow delete: if false;
    }

    match /user_settings/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    match /scraped-data/{date} {
      allow read: if isActiveStaff();
      allow write: if false;
    }

    match /service_refresh_locks/{date} {
      allow read: if isActiveStaff();
      allow create, update: if isActiveStaff() && isValidRefreshLockPayload(date);
      allow delete: if false;
    }

    match /flight_status_cache/{date} {
      allow read: if isActiveStaff();
      allow create, update: if isActiveStaff() && isValidFlightStatusCachePayload(date);
      allow delete: if false;
    }

    match /flight_status_refresh_locks/{date} {
      allow read: if isActiveStaff();
      allow create, update: if isActiveStaff()
        && isCurrentServiceDate(date)
        && isValidRefreshLockPayload(date)
        && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if false;
    }

    match /service_activity/{date}/entries/{entryId} {
      allow read: if isActiveStaff();
      allow create: if isActiveStaff() && isValidActivityPayload(date);
      allow update, delete: if false;
    }

    // Required for collectionGroup('entries') leaderboard queries.
    match /{path=**}/entries/{entryId} {
      allow read: if isActiveStaff();
      allow write: if false;
    }

    match /access_requests/{uid} {
      allow get: if isAdminStaff() || (isSignedIn() && request.auth.uid == uid);
      allow list: if isAdminStaff();
      allow create: if isValidOwnAccessRequestCreate(uid) || isValidAdminBlockedAccessDecision(uid);
      allow update: if isValidOwnAccessRequestUpdate(uid) || isValidStaffAccessDecision(uid) || isValidAdminBlockedAccessDecision(uid);
      allow delete: if false;
    }

    match /access_blocks_uid/{uid} {
      allow read, write: if false;
    }

    match /access_blocks_email/{emailNormalized} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
